# Copy to .env.production.local and fill real production values.
# .env.production.local is ignored by git.

APP_ENV=production
APP_URL=https://your-laleme-domain.example

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_TOKEN=

NEXT_PUBLIC_MAP_STYLE_URL=https://your-map-style.example.com/style.json
NEXT_PUBLIC_DEFAULT_MAP_LATITUDE=22.319300
NEXT_PUBLIC_DEFAULT_MAP_LONGITUDE=114.169400

# Use one or more comma-separated Geofabrik ids for scheduled sync.
# Use --all-geofabrik manually only after validating storage, runtime, quota, and rate limits.
OSM_GEOFABRIK_IDS=hong-kong
OSM_GEOFABRIK_URLS=
OSM_GEOFABRIK_INDEX_URL=https://download.geofabrik.de/index-v1.json
OSM_CACHE_DIR=.data/osm
OSM_BATCH_SIZE=500
