# LaLeMe production-style environment example.
# Do not commit real secrets.

APP_NAME=LaLeMe
APP_ENV=production
APP_URL=https://laleme.example.com

# Hosted Supabase only. Do not use localhost, 127.0.0.1, 192.168.*, or LAN URLs.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secrets. Keep these in deployment secrets / CI / cron, never in browser code.
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_TOKEN=

# Real MapLibre style JSON URL. Do not use OpenStreetMap official tile servers as production CDN.
NEXT_PUBLIC_MAP_STYLE_URL=https://your-map-style.example.com/style.json
NEXT_PUBLIC_DEFAULT_MAP_LATITUDE=22.319300
NEXT_PUBLIC_DEFAULT_MAP_LONGITUDE=114.169400

# Geofabrik / OpenStreetMap extract importer.
# Examples: hong-kong, monaco, us/california
OSM_GEOFABRIK_IDS=hong-kong
OSM_GEOFABRIK_URLS=
OSM_GEOFABRIK_INDEX_URL=https://download.geofabrik.de/index-v1.json
OSM_CACHE_DIR=.data/osm
OSM_BATCH_SIZE=500

PUBLIC_CONTACT_EMAIL=
